# ──────────────────────────────────────────────────────────────
# .env.example — Variables de entorno de referencia
# INSTRUCCIONES:
#   cp .env.example .env
#   Editar .env con valores reales (nunca commitear .env)
# ──────────────────────────────────────────────────────────────

# Base de datos
DB_USER=postgrado_user
DB_PASSWORD=cambiar_en_produccion
DB_NAME=postgrado_dev
DATABASE_URL=postgresql://postgrado_user:cambiar_en_produccion@localhost:5432/postgrado_dev

# JWT
JWT_SECRET=cambiar_en_produccion_por_secreto_seguro_de_minimo_32_caracteres
JWT_EXPIRATION=8h
JWT_REFRESH_EXPIRATION=7d

# Storage de archivos
STORAGE_PATH=/var/postgrado-storage
MAX_FILE_SIZE_MB=5

# Email (SMTP)
SMTP_HOST=mailhog          # En desarrollo: usa MailHog. En prod: smtp.utn.edu.ar
SMTP_PORT=1025             # MailHog usa 1025. SMTP real usa 587
SMTP_USER=                 # Solo para producción
SMTP_PASSWORD=             # Solo para producción
EMAIL_FROM=noreply@posgrado.frlp.utn.edu.ar

# Frontend
VITE_API_URL=http://localhost:8000/api/v1

# Configuración
NODE_ENV=development       # development | production
PORT=8000
CORS_ORIGIN=http://localhost:3000
